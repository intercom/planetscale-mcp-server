# PlanetScale authentication. Two methods are supported; OAuth2 takes precedence
# when both are set.

# --- OAuth2 (recommended; required for /internal API tools) -----------------
# Required by tools that hit the /internal API surface, including:
#   - get_infrastructure
#   - get_metrics
# Get this by running `pscale auth login` and copying the token from your
# CLI's secure store (macOS: `security find-generic-password -s pscale -a access-token -w`).
# PLANETSCALE_OAUTH2_ACCESS_TOKEN=pscale_oauth_...

# --- Service token (works for /v1 API tools only) --------------------------
# Service tokens have access to the public /v1 API but CANNOT reach /internal
# endpoints. Tools that depend on /internal will return an authentication
# error if only this is set.
# Format: <token-id>:<token-secret>
# Get one from: https://app.planetscale.com/<org>/settings/service-tokens
# PLANETSCALE_API_TOKEN=your-token-id:pscale_tkn_your-token-secret

# Optional: override PlanetScale docs MCP endpoint
# PLANETSCALE_DOCS_MCP_URL=https://planetscale.com/docs/mcp
